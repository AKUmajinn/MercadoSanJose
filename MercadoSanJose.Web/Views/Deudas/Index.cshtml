@using MercadoSanJose.Web.Models.ViewModels
@model List<DeudaListItemVM>
@{
    ViewData["Title"] = "Gestión de Deudas";
    var filtro = ViewBag.Filtro as FiltroDeudasVM
                 ?? new FiltroDeudasVM();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt-cutoff"></i> Deudas</h2>
    <div>
        <a asp-action="GenerarIndividual" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Deuda
        </a>
        <a asp-action="GenerarMasiva" class="btn btn-warning ms-2">
            <i class="bi bi-lightning-charge-fill"></i> Generación Masiva
        </a>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-light"><strong>Filtros de Búsqueda</strong></div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Nro. Puesto</label>
                    <input type="text" name="NumeroPuesto" value="@filtro.NumeroPuesto"
                           class="form-control" placeholder="Ej: A-01" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">DNI Responsable</label>
                    <input type="text" name="DNIResponsable" value="@filtro.DNIResponsable"
                           class="form-control" placeholder="Ej: 12345678" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select name="Estado" class="form-select">
                        <option value="">Todos</option>
                        <option value="0">Pendiente</option>
                        <option value="1">Pagada</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <input type="date" name="FechaDesde" value="@filtro.FechaDesde?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <input type="date" name="FechaHasta" value="@filtro.FechaHasta?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-secondary">Buscar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No se encontraron deudas con los filtros aplicados.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Puesto</th>
                        <th>Concepto</th>
                        <th>Emisión</th>
                        <th>Responsable</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td><strong>@d.NumeroPuesto</strong> (@d.Sector)</td>
                            <td>@d.NombreConcepto</td>
                            <td>@d.FechaEmision.ToString("dd/MM/yyyy")</td>
                            <td>
                                @d.NombreResponsable<br />
                                <small class="text-muted">@d.DNIResponsable</small>
                            </td>
                            <td class="fw-bold">S/ @d.MontoTotal.ToString("N2")</td>
                            <td>
                                @if (d.Estado == MercadoSanJose.Web.Models.Enums.EstadoDeuda.Pendiente)
                                {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Pagada</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Detalle" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary shadow-sm">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                   
                                    @if (d.Estado == MercadoSanJose.Web.Models.Enums.EstadoDeuda.Pagada)
                                    {
                                        <a asp-action="GenerarReciboPdf" asp-route-deudaId="@d.Id" class="btn btn-sm btn-danger shadow-sm">
                                            <i class="bi bi-file-earmark-pdf"></i> PDF
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted mt-2 small">Total: @Model.Count registro(s)</p>
}