@using MercadoSanJose.Web.Models.ViewModels
@model ResultadoGeneracionMasiva
@{
    ViewData["Title"] = "Resultado de Generación Masiva";
}
<h2 class="mb-4"><i class="bi bi-check2-all"></i> Resultado de Generación Masiva</h2>

@if (Model == null)
{
    <div class="alert alert-warning">No hay datos de resultado.</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-primary text-center">
                <div class="card-body">
                    <div class="display-5 fw-bold text-primary">@Model.TotalProcesados</div>
                    <small class="text-muted">Procesados</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success text-center">
                <div class="card-body">
                    <div class="display-5 fw-bold text-success">@Model.TotalExitosos</div>
                    <small class="text-muted">Exitosos</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger text-center">
                <div class="card-body">
                    <div class="display-5 fw-bold text-danger">@Model.TotalErrores</div>
                    <small class="text-muted">Errores</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info text-center">
                <div class="card-body">
                    <div class="display-5 fw-bold text-info">S/ @Model.MontoTotalGenerado.ToString("N2")</div>
                    <small class="text-muted">Total Generado</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Detalle por Puesto</div>
        <div class="card-body p-0">
            <table class="table table-sm table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Puesto</th>
                        <th>Responsable Asignado</th>
                        <th>Motivo (RF-05)</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Detalles.Count; i++)
                    {
                        var d = Model.Detalles[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@d.Mensaje</td>
                            <td><strong>@d.ResponsableAsignado</strong></td>
                            <td><small class="text-muted">@d.MotivoAsignacion</small></td>
                            <td>
                                @if (d.Exitoso) { <span class="badge bg-success">OK</span> }
                                else { <span class="badge bg-danger">Error</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <a href="/Deudas/GenerarMasiva" class="btn btn-outline-primary mt-3">Nueva Generación</a>
}
