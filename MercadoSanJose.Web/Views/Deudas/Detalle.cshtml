@model MercadoSanJose.Web.Models.Deuda
@{
    ViewData["Title"] = "Detalle de Deuda";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-info-circle"></i> Detalle de Deuda #@Model.Id</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver al Listado
        </a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Información General</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 150px;">Estado:</th>
                            <td>
                                @if (Model.Estado == MercadoSanJose.Web.Models.Enums.EstadoDeuda.Pendiente)
                                {
                                    <span class="badge bg-warning text-dark fs-6">Pendiente</span>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">Pagada</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Fecha Emisión:</th>
                            <td>@Model.FechaEmision.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <th>Concepto:</th>
                            <td>@Model.ConceptoDeuda.Nombre</td>
                        </tr>
                        <tr>
                            <th>Monto Total:</th>
                            <td class="fw-bold text-danger fs-5">S/ @Model.MontoTotal.ToString("N2")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="card-title mb-0">Ubicación y Responsable</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 150px;">Nro. Puesto:</th>
                            <td>@Model.Puesto.NumeroPuesto</td>
                        </tr>
                        <tr>
                            <th>Sector:</th>
                            <td>@Model.Puesto.Sector</td>
                        </tr>
                        <tr>
                            <th>Responsable:</th>
                            <td><strong>@Model.Responsable.Nombre</strong></td>
                        </tr>
                        <tr>
                            <th>DNI:</th>
                            <td>@Model.Responsable.DNI</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Estado == MercadoSanJose.Web.Models.Enums.EstadoDeuda.Pagada)
    {
        <div class="card shadow-sm mt-2">
            <div class="card-header bg-success text-white">
                <h5 class="card-title mb-0">Acciones Disponibles</h5>
            </div>
            <div class="card-body">
                <a asp-action="GenerarReciboPdf" asp-route-deudaId="@Model.Id" class="btn btn-danger" target="_blank">
                    <i class="bi bi-file-earmark-pdf"></i> Descargar Comprobante PDF
                </a>
            </div>
        </div>
    }
</div>