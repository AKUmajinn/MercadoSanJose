@{
    ViewData["Title"] = "Tablero de Control";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-dark">
                <i class="bi bi-speedometer2 text-primary"></i> Panel de Control - Mercado San José
            </h1>
            <p class="text-muted">Resumen ejecutivo de la gestión de puestos y recaudación financiera.</p>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card border-0 border-start border-4 border-primary shadow-sm h-100">
                <div class="card-body">
                    <div class="text-uppercase small fw-bold text-primary mb-1">Total Puestos</div>
                    <div class="h3 mb-0 fw-bold">17</div>
                    <div class="mt-2 text-muted small">Registrados en el sistema</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-4 border-warning shadow-sm h-100">
                <div class="card-body">
                    <div class="text-uppercase small fw-bold text-warning mb-1">Deudas Pendientes</div>
                    <div class="h3 mb-0 fw-bold">S/ 1,240.00</div>
                    <div class="mt-2 text-muted small">Por cobrar (Morosidad)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-4 border-success shadow-sm h-100">
                <div class="card-body">
                    <div class="text-uppercase small fw-bold text-success mb-1">Caja del Día</div>
                    <div class="h3 mb-0 fw-bold">S/ 450.00</div>
                    <div class="mt-2 text-muted small">Recaudación de hoy</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 border-start border-4 border-info shadow-sm h-100">
                <div class="card-body">
                    <div class="text-uppercase small fw-bold text-info mb-1">Locales Alquilados</div>
                    <div class="h3 mb-0 fw-bold">8</div>
                    <div class="mt-2 text-muted small">Con inquilinos activos</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-gear-fill"></i> Operaciones Críticas</h5>
                    <div class="list-group list-group-flush">
                        <a href="/Deudas/GenerarMasiva" class="list-group-item list-group-item-action border-0 px-0 py-3">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1 fw-bold text-success">Generación de Deuda Masiva (RF-05)</h6>
                                <i class="bi bi-chevron-right"></i>
                            </div>
                            <p class="mb-1 small text-muted">Aplicar el algoritmo de asignación dinámica a todos los locales.</p>
                        </a>
                        <a href="/Deudas/Buscar" class="list-group-item list-group-item-action border-0 px-0 py-3">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1 fw-bold text-primary">Registro de Cobros (RF-06)</h6>
                                <i class="bi bi-chevron-right"></i>
                            </div>
                            <p class="mb-1 small text-muted">Búsqueda rápida de deudas por DNI o número de puesto.</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-file-earmark-bar-graph"></i> Reportes de Auditoría</h5>
                    <div class="row g-2">
                        <div class="col-6">
                            <a href="/Deudas/CajaDiaria" class="btn btn-outline-dark w-100 py-3">
                                <i class="bi bi-calendar-check d-block fs-3 mb-2"></i>
                                <span class="small">Caja Diaria</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="/Deudas/Morosidad" class="btn btn-outline-danger w-100 py-3">
                                <i class="bi bi-exclamation-octagon d-block fs-3 mb-2"></i>
                                <span class="small">Morosidad</span>
                            </a>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>